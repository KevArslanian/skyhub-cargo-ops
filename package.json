{
  "name": "skyhub-cargo-ops",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm prisma:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "qa:visual": "node scripts/visual-qa.mjs",
    "test": "pnpm test:api && pnpm test:e2e",
    "test:api": "pnpm exec playwright test tests/regression.spec.ts --grep @api --reporter=line",
    "test:e2e": "pnpm exec playwright test tests/regression.spec.ts --grep @e2e --reporter=line",
    "qa:crud": "pnpm exec playwright test tests/regression.spec.ts --grep @crud --reporter=line",
    "qa:regression": "pnpm exec playwright test tests/regression.spec.ts --reporter=line",
    "qa:regression:headed": "pnpm exec playwright test tests/regression.spec.ts --headed --reporter=line",
    "qa:all": "pnpm lint && pnpm exec prisma validate && pnpm exec prisma migrate status && pnpm build && pnpm qa:regression && pnpm qa:visual",
    "db:migrate": "pnpm prisma:generate && prisma migrate deploy",
    "db:migrate:unpooled": "node scripts/migrate-unpooled.mjs",
    "db:push": "pnpm prisma:sync-schema && prisma db push",
    "db:seed": "pnpm prisma:generate && tsx prisma/seed.ts",
    "prisma:generate": "pnpm prisma:sync-schema && prisma generate",
    "prisma:sync-schema": "node scripts/sync-prisma-schema.mjs"
  },
  "dependencies": {
    "@deltaoga/skyhub-print-center": "github:KevArslanian/skyhub-print-center#v1.1.1",
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.59.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  }
}
