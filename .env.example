# Core database provider
DATABASE_PROVIDER=postgresql

# Runtime pooled database URL (Neon pooled connection string)
DATABASE_URL=

# Migration-only direct/unpooled URL (Neon direct connection string)
DATABASE_URL_UNPOOLED=

# Session key for auth cookies/JWT
SESSION_SECRET=

# Optional local/development override for secure auth cookie behavior.
# Production always uses secure cookies.
AUTH_COOKIE_SECURE=

# Optional locally. Required in production for document upload/download/delete.
BLOB_READ_WRITE_TOKEN=
