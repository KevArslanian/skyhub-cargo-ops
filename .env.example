# Core database provider
DATABASE_PROVIDER=postgresql

# Runtime pooled database URL (Neon pooled connection string)
DATABASE_URL=

# Migration-only direct/unpooled URL (Neon direct connection string)
DATABASE_URL_UNPOOLED=

# Session key for auth cookies/JWT
SESSION_SECRET=

# Optional override for secure auth cookie behavior
AUTH_COOKIE_SECURE=

# Optional Vercel Blob token (uploads fallback to local/tmp when empty)
BLOB_READ_WRITE_TOKEN=
